      <Type>IO</Type>
      <Payload>500</Payload>
      <Priority>3</Priority>
    </Job>
    <Job>
      <Type>Prime</Type>
      <Payload>50000,2</Payload>
      <Priority>2</Priority>
    </Job>
    <Job>
      <Type>IO</Type>
      <Payload>1200</Payload>
      <Priority>5</Priority>
    </Job>
    <Job>
      <Type>IO</Type>
      <Payload>2500</Payload>
      <Priority>4</Priority>
    </Job>
    <Job>
      <Type>Prime</Type>
      <Payload>200000,8</Payload>
      <Priority>1</Priority>
    </Job>
  </InitialJobs>
</Configuration>
